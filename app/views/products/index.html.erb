<h1><%= t "hello" %></h1>

<h1>Products</h1>
<p>Find me in app/views/products/index.html.erb</p>

<%= link_to "New Product", new_product_path if authenticated? %>
<div id="products">
  <% @products.each do |product| %>
    <div>
      <%= link_to product.name, product_path(product.id) %>
    </div>
  <% end %>
  <p><%= product_url(1) %></p>
</div>
